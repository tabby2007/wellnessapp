<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="#01579B"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoalsActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weakly Goals"
            android:textSize="25sp"
            android:textAlignment="center"
            android:background="@drawable/shape2"
            android:padding="10dp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/weeklygoals"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/recipesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Goals \n.Why weekly goals matter: \n\n1.They break big health objectives into manageable steps. \n\n2.Help you stay consistent and motivated. \n\n3.Allow you to track progress regularly. \n\n4.Encourage healthy routines and discipline."
            android:textSize="16sp"
            android:padding="16dp"/>

    </LinearLayout>

</ScrollView>